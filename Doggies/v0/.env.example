# Anthropic
ANTHROPIC_API_KEY=XXX

# Supabase
SUPABASE_URL=XXX
SUPABASE_KEY=XXX

# Telegram
TELEGRAM_BOT_TOKEN=XXX
TELEGRAM_ADMIN_CHAT_ID=XXX

# Google Calendar (project-local service account)
# Get the Calendar ID from: Google Calendar → Settings → Integrate calendar
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
# Path to the service account JSON key file (relative to project root, gitignored)
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/google_calendar.json

# Donation links
DONATION_ONETIME_URL=XXX
DONATION_RECURRING_URL=XXX

# App
APP_ENV=development
LOG_LEVEL=INFO
